# Zmienne środowiskowe - skopiuj ten plik jako .env i uzupełnij wartości

# Tajny klucz do podpisywania cookies - wygeneruj losowy ciąg min. 32 znaków
# Przykład: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=zmien-na-losowy-dlugi-ciag-znakow-min-32-znaki

# Login administratora superadmin (nie email, tylko nazwa użytkownika)
ADMIN_LOGIN=superadmin

# Środowisko uruchomieniowe (production / development)
NODE_ENV=production

# Port aplikacji (domyślnie 3000)
PORT=3000
